# 办公小浣熊 / 商汤 SenseNova（比赛提交推荐）
SENSENOVA_API_KEY=your-sensenova-api-key
MODEL=openai/SenseChat-5
BASE_URL=https://api.sensenova.cn/compatible-mode/v2

# 可选：Demo 启用小浣熊原生联网检索（主体尽调，与工作流一致）
# SENSENOVA_SEARCH_ENABLE=true

# 开发调试可改用其他模型（界面 Provider 切换后需对应 Key）
# OPENAI_API_KEY=sk-...
# MODEL=openai/gpt-4o-mini
# BASE_URL=

# DEEPSEEK_API_KEY=sk-...
# MODEL=deepseek/deepseek-chat

# 可选：本地 LM Studio
# VLLM_API_KEY=lm-studio
# MODEL=hosted_vllm/gemma-4-e4b-it
# BASE_URL=http://127.0.0.1:1234/v1

CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false

# ── 飞书知识库合同审核闭环（scripts/feishu_contract_loop.py）─────
# 配置后可轮询飞书知识库新合同 → 自动审核 → 报告写回 + 多维表格沉淀
# 获取 space_id: lark-cli wiki +space-list --as user --format json
# 获取节点 token: lark-cli wiki +node-list --space-id <ID> --as user
# FEISHU_WIKI_SPACE_ID=             # 知识库空间 ID
# FEISHU_CONTRACT_NODE=             # 存放待审合同的父节点 token（留空监控根节点）
# FEISHU_REPORT_NODE=               # 审核报告挂载的父节点 token（留空则用 CONTRACT_NODE）
# FEISHU_BITABLE_APP=               # 多维表格 app_token（结构化记录沉淀）
# FEISHU_BITABLE_TABLE=             # 多维表格 table_id 或表名
# FEISHU_LOOP_REVIEW_MODE=rules_only # 审核模式：rules_only | rules_agent
# FEISHU_LOOP_LLM_PROVIDER=deepseek  # rules_agent 时 LLM Provider：deepseek | sensenova
